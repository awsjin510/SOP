{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cloudorange.tw/schemas/ir.json",
  "title": "SOP Intermediate Representation",
  "description": "完整的 SOP 中介表示，是所有抽取器與渲染器之間的契約",
  "type": "object",
  "required": ["meta", "sections", "steps", "version", "schema_version"],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0"],
      "description": "IR Schema 版本"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "SOP 自身版本（semver）"
    },
    "meta": {
      "type": "object",
      "required": ["sop_id", "title", "target_audience", "created_at", "updated_at"],
      "properties": {
        "sop_id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "業務識別碼（kebab-case）"
        },
        "title": { "type": "string", "maxLength": 200 },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "target_audience": { "type": "string" },
        "estimated_duration_minutes": { "type": "integer", "minimum": 0 },
        "difficulty": { "type": "string", "enum": ["初級", "中級", "進階"] },
        "authors": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "last_reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "sections": {
      "type": "array",
      "description": "章節清單（用於目錄）",
      "items": {
        "type": "object",
        "required": ["id", "title", "order"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "order": { "type": "integer", "minimum": 0 },
          "description": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "操作步驟（核心內容）",
      "items": { "$ref": "#/definitions/step" }
    },
    "troubleshooting": {
      "type": "array",
      "items": { "$ref": "#/definitions/troubleshooting_item" }
    },
    "glossary": {
      "type": "array",
      "items": { "$ref": "#/definitions/glossary_term" }
    },
    "checklists": {
      "type": "array",
      "items": { "$ref": "#/definitions/checklist" }
    },
    "appendix": {
      "type": "object",
      "properties": {
        "references": { "type": "array", "items": { "type": "string" } },
        "related_sops": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "definitions": {
    "step": {
      "type": "object",
      "required": ["step_id", "section_id", "title", "actions", "source_refs"],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^step-[a-zA-Z0-9_-]+$",
          "description": "穩定 ID，跨版本永不變動。建議用 nanoid 產生"
        },
        "section_id": { "type": "string" },
        "order": { "type": "integer", "minimum": 0 },
        "title": { "type": "string", "maxLength": 200 },
        "purpose": {
          "type": "string",
          "description": "做這步的目的（內訓重要）"
        },
        "preconditions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "執行前的前置條件"
        },
        "actions": {
          "type": "array",
          "description": "具體操作動作",
          "items": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": { "type": "string" },
              "command": { "type": "string", "description": "可選的指令範例" },
              "screenshot_refs": {
                "type": "array",
                "items": { "type": "string", "description": "對應 assets/images.yaml 的 image_id" }
              }
            }
          }
        },
        "expected_result": {
          "type": "string",
          "description": "預期看到的結果"
        },
        "common_mistakes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tips": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "重要警示（會出大事的那種）"
        },
        "estimated_duration_minutes": { "type": "integer", "minimum": 0 },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/source_ref" }
        },
        "needs_human_input": {
          "type": "boolean",
          "default": false,
          "description": "標記此步驟需要人工確認"
        },
        "human_input_reason": { "type": "string" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "AI 抽取的信心程度"
        }
      }
    },
    "troubleshooting_item": {
      "type": "object",
      "required": ["id", "symptom", "source_refs"],
      "properties": {
        "id": { "type": "string", "pattern": "^trouble-[a-zA-Z0-9_-]+$" },
        "symptom": { "type": "string" },
        "cause": { "type": "string" },
        "solution": { "type": "string" },
        "related_step_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "severity": {
          "type": "string",
          "enum": ["低", "中", "高", "嚴重"]
        },
        "source_refs": {
          "type": "array",
          "items": { "$ref": "#/definitions/source_ref" }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "glossary_term": {
      "type": "object",
      "required": ["id", "term", "definition"],
      "properties": {
        "id": { "type": "string", "pattern": "^term-[a-zA-Z0-9_-]+$" },
        "term": { "type": "string" },
        "definition": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "see_also": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "checklist": {
      "type": "object",
      "required": ["id", "title", "items"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "purpose": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": { "type": "string" },
              "step_ref": { "type": "string" }
            }
          }
        }
      }
    },
    "source_ref": {
      "type": "object",
      "required": ["source_file", "extractor_type"],
      "properties": {
        "source_file": {
          "type": "string",
          "description": "原始素材檔名"
        },
        "extractor_type": {
          "type": "string",
          "enum": ["transcript", "document", "screenshot", "change_list", "text", "pdf"]
        },
        "location": {
          "type": "string",
          "description": "素材內位置（如『第三段』『第 2 頁』『時間軸 02:15』）"
        },
        "excerpt": {
          "type": "string",
          "description": "原文片段（協助追溯）"
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
